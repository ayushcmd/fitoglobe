generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── USERS ────────────────────────────────────────────────
model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String
  password      String? // null for Google OAuth users
  googleId      String?   @unique
  avatar        String?
  language      String    @default("en") // en|es|ja|ko
  country       String? // country code e.g. "IN"
  countryName   String?
  countryDiet   String? // diet type e.g. "indian"
  height        Float? // cm
  weight        Float? // kg
  age           Int?
  unit          String    @default("metric") // metric|imperial
  goal          String? // gain|maintain|lose
  isVerified    Boolean   @default(false)
  resetToken    String?
  resetTokenExp DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  workoutSessions WorkoutSession[]
  nutritionLogs   NutritionLog[]
  progressLogs    ProgressLog[]
  aiConversations AIConversation[]

  @@map("users")
}

// ─── EXERCISES (seed data) ────────────────────────────────
model Exercise {
  id             String  @id @default(cuid())
  name           String
  nameEs         String?
  nameJa         String?
  nameKo         String?
  muscleGroup    String // chest|back|legs|shoulders|arms|core
  equipment      String // Barbell|Dumbbell|Machine|Bodyweight|Cable
  difficulty     String  @default("intermediate") // beginner|intermediate|advanced
  defaultSets    Int     @default(3)
  defaultReps    Int     @default(12)
  caloriesPerMin Float   @default(6.0)
  videoUrl       String?
  description    String?

  sessionExercises SessionExercise[]

  @@map("exercises")
}

// ─── WORKOUT PLANS ────────────────────────────────────────
model WorkoutPlan {
  id          String   @id @default(cuid())
  name        String
  description String?
  goal        String // gain|maintain|lose
  daysPerWeek Int      @default(3)
  isPublic    Boolean  @default(false)
  createdAt   DateTime @default(now())

  sessions WorkoutSession[]

  @@map("workout_plans")
}

// ─── WORKOUT SESSIONS ─────────────────────────────────────
model WorkoutSession {
  id             String   @id @default(cuid())
  userId         String
  planId         String?
  name           String
  notes          String?
  durationMin    Int?
  caloriesBurned Float?
  completedAt    DateTime @default(now())

  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan      WorkoutPlan?      @relation(fields: [planId], references: [id])
  exercises SessionExercise[]

  @@map("workout_sessions")
}

// ─── SESSION EXERCISES (sets/reps log) ───────────────────
model SessionExercise {
  id         String  @id @default(cuid())
  sessionId  String
  exerciseId String
  sets       Int
  reps       Int
  weightKg   Float?
  notes      String?

  session  WorkoutSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  exercise Exercise       @relation(fields: [exerciseId], references: [id])

  @@map("session_exercises")
}

// ─── NUTRITION LOGS ───────────────────────────────────────
model NutritionLog {
  id       String   @id @default(cuid())
  userId   String
  date     DateTime @default(now())
  mealType String // breakfast|lunch|dinner|snack
  foodName String
  calories Float
  proteinG Float    @default(0)
  carbsG   Float    @default(0)
  fatG     Float    @default(0)
  quantity Float    @default(1)
  unit     String   @default("serving")
  notes    String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("nutrition_logs")
}

// ─── PROGRESS LOGS ────────────────────────────────────────
model ProgressLog {
  id         String   @id @default(cuid())
  userId     String
  date       DateTime @default(now())
  weightKg   Float?
  bodyFatPct Float?
  chestCm    Float?
  waistCm    Float?
  hipsCm     Float?
  armCm      Float?
  thighCm    Float?
  notes      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("progress_logs")
}

// ─── AI CONVERSATIONS ─────────────────────────────────────
model AIConversation {
  id        String   @id @default(cuid())
  userId    String
  messages  Json // array of {role, content, timestamp}
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("ai_conversations")
}
